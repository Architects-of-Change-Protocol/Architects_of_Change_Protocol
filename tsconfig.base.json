{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@aoc-runtime/shared-types": [
        "packages/shared-types/src"
      ],
      "@aoc-runtime/provider-interfaces": [
        "packages/provider-interfaces/src"
      ],
      "@aoc-runtime/governance-runtime": [
        "packages/governance-runtime/src"
      ],
      "@aoc-runtime/consent-runtime": [
        "packages/consent-runtime/src"
      ],
      "@aoc-runtime/capability-runtime": [
        "packages/capability-runtime/src"
      ],
      "@aoc-runtime/audit-runtime": [
        "packages/audit-runtime/src"
      ],
      "@aoc-runtime/portable-cognition": [
        "packages/portable-cognition/src"
      ],
      "@aoc-runtime/vault-runtime": [
        "packages/vault-runtime/src"
      ],
      "@aoc-runtime/authorization-runtime": [
        "packages/authorization-runtime/src"
      ],
      "@aoc-runtime/trust-registry-runtime": [
        "packages/trust-registry-runtime/src"
      ],
      "@aoc/capability-tokens": [
        "packages/capability-tokens/src"
      ],
      "@aoc/consent-engine": [
        "packages/consent-engine/src"
      ],
      "@aoc/identity": [
        "packages/identity/src"
      ],
      "@aoc/scoped-access": [
        "packages/scoped-access/src"
      ],
      "@aoc/audit-sdk": [
        "packages/audit-sdk/src"
      ]
    }
  }
}
