{
  "name": "aoc-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "workspaces": [
    "packages/*",
    "examples/*",
    "enterprise"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "jest",
    "lint": "npm run typecheck && npm run lint:semantic-ownership",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "release:status": "changeset status --verbose",
    "release:dry-run": "npm run validate:release && changeset status --verbose",
    "check:version-graph": "node scripts/check-version-graph.mjs",
    "validate:publishability": "node scripts/validate-publishability.mjs",
    "lint:semantic-ownership": "node scripts/lint-semantic-ownership.mjs",
    "check:runtime-boundaries": "node scripts/check-runtime-boundaries.mjs",
    "check:identity-vocabulary": "node scripts/check-identity-vocabulary.mjs",
    "check:contract-drift": "node scripts/check-contract-drift.mjs",
    "validate:release": "npm run check:aoc-boundaries && npm run typecheck && npm run build && npm run lint && npm test && npm run lint:semantic-ownership && npm run check:version-graph && npm run check:constitutional-amendments && npm run check:constitutional-versioning && npm run check:authority-governance && npm run check:capability-governance && npm run check:policy-governance && npm run check:decision-governance && npm run validate:publishability && npm pack ./packages/protocol",
    "check:policy-governance": "node scripts/check-policy-governance.mjs",
    "check:reason-code-governance": "node scripts/check-reason-code-governance.mjs",
    "check:capability-governance": "node scripts/check-capability-governance.mjs",
    "check:execution-governance": "node scripts/check-execution-governance.mjs",
    "check:federation-governance": "node scripts/check-federation-governance.mjs",
    "check:intent-governance": "node scripts/check-intent-governance.mjs",
    "check:runtime-exports": "node scripts/check-runtime-export-governance.mjs",
    "check:persistence-boundaries": "node scripts/check-runtime-boundaries.mjs",
    "check:sdk-boundaries": "node scripts/check-sdk-import-boundary.mjs",
    "check:sdk-examples": "node scripts/check-sdk-examples-compile.mjs",
    "check:release-governance": "node scripts/check-release-governance.mjs",
    "check:observability-governance": "node scripts/check-observability-governance.mjs",
    "check:memory-governance": "node scripts/check-memory-governance.mjs",
    "check:sdk-exports": "node scripts/check-sdk-exports.mjs",
    "check:temporal-governance": "node scripts/check-temporal-governance.mjs",
    "check:symbol-parity": "node scripts/check-symbol-parity.mjs",
    "check:aoc-boundaries": "npm run check:constitutional-boundaries && npm run check:constitutional-amendments && npm run check:constitutional-versioning && npm run check:authority-governance && npm run check:capability-authorities && npm run check:capability-delegation && npm run check:capability-governance && npm run check:capability-revocation && npm run check:policy-authorities && npm run check:policy-hierarchy && npm run check:policy-conflicts && npm run check:policy-exceptions && npm run check:policy-governance && npm run check:decision-authorities && npm run check:decision-lifecycle && npm run check:decision-evidence && npm run check:decision-explainability && npm run check:decision-appeals && npm run check:decision-governance && npm run check:ownership-boundaries && npm run check:public-export-governance && npm run check:composition-boundaries && npm run lint:semantic-ownership && npm run check:runtime-boundaries && npm run check:symbol-parity && npm run check:enterprise-package-boundary && npm run check:legacy-runtime-compatibility",
    "check:enterprise-package-boundary": "node scripts/check-enterprise-package-boundary.mjs",
    "check:legacy-runtime-compatibility": "node scripts/check-legacy-runtime-compatibility.mjs",
    "check:constitutional-boundaries": "node scripts/check-constitutional-boundaries.mjs",
    "check:ownership-boundaries": "node scripts/check-ownership-boundaries.mjs",
    "check:public-export-governance": "node scripts/check-public-export-governance.mjs",
    "check:composition-boundaries": "node scripts/check-composition-boundaries.mjs",
    "check:constitutional-amendments": "node scripts/check-constitutional-amendments.mjs",
    "check:constitutional-versioning": "node scripts/check-constitutional-versioning.mjs",
    "check:authority-governance": "node scripts/check-authority-governance.mjs",
    "check:capability-authorities": "node scripts/check-capability-authorities.mjs",
    "check:capability-delegation": "node scripts/check-capability-delegation.mjs",
    "check:capability-revocation": "node scripts/check-capability-revocation.mjs",
    "check:policy-authorities": "node scripts/check-policy-authorities.mjs",
    "check:policy-hierarchy": "node scripts/check-policy-hierarchy.mjs",
    "check:policy-conflicts": "node scripts/check-policy-conflicts.mjs",
    "check:policy-exceptions": "node scripts/check-policy-exceptions.mjs",
    "check:decision-authorities": "node scripts/check-decision-authorities.mjs",
    "check:decision-lifecycle": "node scripts/check-decision-lifecycle.mjs",
    "check:decision-evidence": "node scripts/check-decision-evidence.mjs",
    "check:decision-explainability": "node scripts/check-decision-explainability.mjs",
    "check:decision-appeals": "node scripts/check-decision-appeals.mjs",
    "check:decision-governance": "node scripts/check-decision-governance.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  },
  "packageManager": "npm@11.4.2",
  "engines": {
    "node": ">=20"
  },
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./runtime": {
      "types": "./runtime/index.d.ts",
      "default": "./runtime/index.js"
    },
    "./runtime/internal": {
      "types": "./runtime/internal.d.ts",
      "default": "./runtime/internal.js"
    },
    "./runtime/experimental": {
      "types": "./runtime/experimental.d.ts",
      "default": "./runtime/experimental.js"
    },
    "./package.json": "./package.json"
  }
}
