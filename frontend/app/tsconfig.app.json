{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "types": ["vite/client", "node"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true
  },
  "include": ["src"],
  "exclude": ["../../protocol", "../../runtime", "node_modules"]
}
